# Firebase Configuration
# Get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Apps Script Configuration
# URL for event registration, email delivery, and admin actions
# Deploy the GOOGLE_APPS_SCRIPT_PRODUCTION.gs script and copy the Web App URL here
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEP_ID_HERE/exec

# Cloudinary Configuration (unsigned upload — safe for frontend)
# Get these from Cloudinary Dashboard
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
